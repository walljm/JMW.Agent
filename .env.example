# Copy this file to .env and fill in real values before running `docker compose up`.
# .env is git-ignored — never commit real secrets.

# Postgres password, shared by the postgres and server services.
# Generate one with: openssl rand -hex 32
JMW_DB_PASSWORD=

# HMAC key used to hash stored agent API keys (see ApiKeyService). Must be at least 32 bytes;
# the server refuses to start if it is short or left at a known placeholder value.
# Generate one with: openssl rand -hex 32
JMW_API_KEY_SECRET=

# OIDC SSO (optional) — leave all four blank to disable SSO entirely (the login button is hidden
# and the callback endpoint 404s). See docs/scratch or your IdP's OIDC client registration.
JMW_OIDC_AUTHORITY=
JMW_OIDC_CLIENT_ID=
JMW_OIDC_CLIENT_SECRET=
JMW_OIDC_CALLBACK_PATH=
