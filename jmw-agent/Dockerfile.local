# Local /addons build fallback. The deploy helper copies this file to
# Dockerfile and removes the image: setting from config.yaml before staging.

FROM ghcr.io/home-assistant/base:latest

ARG BUILD_ARCH
ARG BUILD_VERSION=dev
LABEL \
    io.hass.version="${BUILD_VERSION}" \
    io.hass.type="app" \
    io.hass.arch="aarch64|amd64"

COPY jmw-agent.${BUILD_ARCH} /usr/bin/jmw-agent
RUN chmod +x /usr/bin/jmw-agent

COPY run.sh /run.sh
RUN chmod +x /run.sh

CMD ["/run.sh"]
