# Copy to /etc/jmw/server.env and fill in values before starting jmw-server.service.
# Permissions: chmod 640, chown root:jmw

JMW_DB_CONNECTION=Host=localhost;Port=5432;Database=jmwdiscovery;Username=jmw;Password=CHANGEME;Search Path=jmwdiscovery,public

# Optional overrides (defaults shown):
# ASPNETCORE_URLS=http://+:8080
# JMW_KEY_RING_PATH=/var/lib/jmw/keyring
# JMW_RETENTION_DAYS=90

# Private CA(s) to trust fleet-wide. Point at a single PEM file or a directory of
# *.pem/*.crt/*.cer files. Distributed to agents in the heartbeat config so their
# validating collectors can authenticate private-CA HTTPS endpoints (e.g. ha.home).
# Read at startup — restart the server to pick up added/rotated CAs.
# JMW_TRUSTED_CA_PATH=/etc/jmw/trusted-ca
