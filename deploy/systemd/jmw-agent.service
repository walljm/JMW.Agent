[Unit]
Description=JMW Agent
After=network.target

[Service]
Type=simple
User=root
Group=root
WorkingDirectory=/var/lib/jmw-agent
ExecStart=/usr/local/bin/jmw-agent -config /etc/jmw/agent.toml
Restart=on-failure
RestartSec=5
NoNewPrivileges=true
ProtectSystem=strict
ReadWritePaths=/var/lib/jmw-agent
ProtectHome=true
PrivateTmp=true

[Install]
WantedBy=multi-user.target
