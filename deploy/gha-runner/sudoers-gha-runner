# Sudoers rule for the GitHub Actions self-hosted runner.
#
# Install at: /etc/sudoers.d/gha-runner   (owner root:root, mode 0440)
# Validate with: visudo -cf /etc/sudoers.d/gha-runner
#
# The runner can execute exactly these two helper scripts as root and
# nothing else. Each script validates its own arguments.

gha-runner ALL=(root) NOPASSWD: /opt/jmw/bin/gha-deploy-server
gha-runner ALL=(root) NOPASSWD: /opt/jmw/bin/gha-publish-agent-release

Defaults!/opt/jmw/bin/gha-deploy-server         !requiretty
Defaults!/opt/jmw/bin/gha-publish-agent-release !requiretty
