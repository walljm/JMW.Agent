<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.walljm.jmw.server</string>
  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/jmw-server</string>
    <string>-config</string>
    <string>/usr/local/etc/jmw/server.toml</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>/usr/local/var/jmw</string>
  <key>StandardErrorPath</key>
  <string>/usr/local/var/log/jmw-server.err.log</string>
  <key>StandardOutPath</key>
  <string>/usr/local/var/log/jmw-server.out.log</string>
</dict>
</plist>
