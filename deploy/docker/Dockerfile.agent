# Multi-stage build for the containerized agent. Unlike the old Go agent, the
# C# build is NOT a static binary — the final stage needs the .NET runtime, so
# it uses the runtime base image (not distroless-static) and a real package
# manager for smartmontools (see below), same trade-off already called out in
# docs/architecture/deployment.md.
#
# The build stage is pinned to --platform=$BUILDPLATFORM (same trick the old
# Go Dockerfile used) rather than letting buildx build it natively per target
# arch: Grpc.Tools' bundled linux_arm64 protoc (used for the OnHub protobuf
# codegen) segfaults (exit 139) when invoked by MSBuild's Exec task under
# arm64, whether native or emulated — reproduced directly against
# mcr.microsoft.com/dotnet/sdk:10.0.300. Forcing the build to always run on
# the builder's own architecture avoids that entirely; the published output
# is framework-dependent IL, so it's architecture-independent and runs fine
# under whichever runtime image the (unpinned) final stage resolves to.
ARG BUILDPLATFORM
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:10.0.300 AS build
WORKDIR /src

# .editorconfig carries analyzer severity overrides and Directory.Build.props sets
# TreatWarningsAsErrors solution-wide — both apply per-directory during a plain
# `dotnet publish`, so copy them even though we're not restoring the full .slnx.
COPY .editorconfig .
COPY Directory.Build.props .

# Project files first (cache layer for restore) — the agent only depends on Core,
# not the lib/ITPIE.* database libraries (those are Server.Web-only).
COPY src/Core/JMW.Discovery.Core.csproj src/Core/
COPY src/Agent/JMW.Discovery.Agent.csproj src/Agent/

COPY src/Core/ src/Core/
COPY src/Agent/ src/Agent/

RUN dotnet publish src/Agent/JMW.Discovery.Agent.csproj -c Release -o /app/publish

FROM mcr.microsoft.com/dotnet/runtime:10.0 AS final
WORKDIR /app
COPY --from=build /app/publish .

# Trust the WallJM Home root CA for the agent's own outbound HTTPS calls to a
# private-CA-issued server host (e.g. core.home) — matches Server.Web/Dockerfile.
COPY deploy/trusted-ca/walljm-home-root-ca.crt /usr/local/share/ca-certificates/walljm-home-root-ca.crt

# smartmontools gives DiskCollector a `smartctl` binary on PATH (it shells out,
# same as on a bare-metal install) — needs --privileged or --device grants at
# `docker run` time to open raw disk devices; see deploy/docker/README.md.
RUN apt-get update \
    && apt-get install -y --no-install-recommends smartmontools ca-certificates \
    && update-ca-certificates \
    && rm -rf /var/lib/apt/lists/* \
    && groupadd --system jmw \
    && useradd --system --gid jmw --no-create-home jmw \
    && mkdir -p /var/lib/jmw-agent /etc/jmw-agent \
    && chown -R jmw:jmw /var/lib/jmw-agent /app

USER jmw

# /var/lib/jmw-agent is the default JMW_AGENT_STATE_DIR (agent-id + API key) —
# mount a named volume there so re-creating the container doesn't re-register.
VOLUME ["/var/lib/jmw-agent"]

ENTRYPOINT ["dotnet", "JMW.Discovery.Agent.dll"]
CMD ["/etc/jmw-agent/agent.json"]
