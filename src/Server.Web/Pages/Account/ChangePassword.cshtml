@page "/account/password"
@model JMW.Discovery.Server.Pages.Account.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password — JMW Discovery";
}

<main class="main">
    <div class="page-head">
        <h1>Change Password</h1>
    </div>

    <div class="section" style="max-width:420px">
        <form method="post">
            @Html.AntiForgeryToken()
            <div class="field">
                <label for="curPw">Current password</label>
                <input class="input" id="curPw" name="CurrentPassword" asp-for="CurrentPassword" type="password"
                       autocomplete="current-password" autofocus>
            </div>
            <div class="field">
                <label for="newPw">New password</label>
                <input class="input" id="newPw" name="NewPassword" asp-for="NewPassword" type="password"
                       autocomplete="new-password">
                <span class="help">At least 8 characters.</span>
            </div>
            <div class="field">
                <label for="confirmPw">Confirm new password</label>
                <input class="input" id="confirmPw" name="ConfirmPassword" asp-for="ConfirmPassword" type="password"
                       autocomplete="new-password">
            </div>
            @if (Model.ErrorMessage is not null)
            {
                <div class="banner error" role="alert">@Model.ErrorMessage</div>
            }
            @if (Model.SuccessMessage is not null)
            {
                <div class="banner info" role="status">@Model.SuccessMessage</div>
            }
            <button class="btn btn-primary" type="submit">Change password</button>
        </form>
    </div>
</main>
