@page "/admin/credentials"
@model JMW.Discovery.Server.Pages.Admin.CredentialsModel
@{
    ViewData["Title"] = "Credentials — JMW Discovery";
    ViewData["ActiveNav"] = "fleet";
}
<main class="main data-grid-page">
    <div class="page-head">
        <h1>Credentials</h1>
        <button class="btn btn-primary" onclick="openCreate()">+ New Credential</button>
    </div>

    <partial name="_HubTabs" model="@(new HubTabsModel(HubTabSets.Fleet, "/admin/credentials", "Fleet views"))"/>

    <p class="prose text-dim">
        Secrets are encrypted at rest and never displayed after creation. Rotate to replace a secret.
    </p>

    <partial name="_FilterBar" model="Model.FilterBar"/>

    <partial name="_CredentialsTable" model="Model"/>
</main>

<!-- Create / Edit credential drawer -->
<div class="modal-scrim" id="credModal" hidden role="dialog" aria-modal="true" aria-labelledby="credTitle">
    <div class="modal">
        <header><h3 id="credTitle">New Credential</h3>
            <button class="btn btn-sm" onclick="closeCred()" aria-label="Close">✕</button>
        </header>
        <div class="body">
            <div class="field"><label for="cName">Name</label><input class="input" id="cName"
                                                                     placeholder="e.g. ssh-root-key"></div>
            <div class="field">
                <label for="cType">Type</label>
                <select class="input" id="cType">
                    <option value="ssh-key">ssh-key</option>
                    <option value="ssh-password">ssh-password</option>
                    <option value="snmp">snmp</option>
                    <option value="api-token">api-token</option>
                </select>
            </div>
            <div class="field" id="cSecretField">
                <label for="cSecret">Secret</label>
                <input class="input" type="password" id="cSecret"
                       placeholder="private key, password, community, or token">
                <span class="help">Stored encrypted. Not shown again after saving.</span>
            </div>
            <p class="help" id="cEditSecretHint" hidden>This only changes the name/type. To
                replace the stored secret, close this and click <strong>Rotate</strong> instead.</p>
        </div>
        <footer>
            <button class="btn" onclick="closeCred()">Cancel</button>
            <button class="btn btn-primary" id="cSave" onclick="saveCred()">Save</button>
        </footer>
    </div>
</div>

<!-- Rotate secret drawer -->
<div class="modal-scrim" id="rotateModal" hidden role="dialog" aria-modal="true" aria-labelledby="rotateTitle">
    <div class="modal">
        <header><h3 id="rotateTitle">Rotate Secret</h3>
            <button class="btn btn-sm" onclick="closeRotate()" aria-label="Close">✕</button>
        </header>
        <div class="body">
            <div class="field">
                <label for="rSecret">New Secret</label>
                <input class="input" type="password" id="rSecret" placeholder="new secret value">
                <span class="help">Replaces the stored secret. The old value is overwritten.</span>
            </div>
        </div>
        <footer>
            <button class="btn" onclick="closeRotate()">Cancel</button>
            <button class="btn btn-primary" onclick="saveRotate()">Rotate</button>
        </footer>
    </div>
</div>

<div class="toast" id="toast" hidden></div>

@section Scripts {
    <script>
        const CSRF = '@Model.AntiforgeryToken';
        let editId = null;   // null = create mode
        let rotateId = null;

        function toast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.hidden = false;
            setTimeout(() => t.hidden = true, 3000);
        }

        function openCreate() {
            editId = null;
            document.getElementById('credTitle').textContent = 'New Credential';
            document.getElementById('cName').value = '';
            document.getElementById('cType').value = 'ssh-key';
            document.getElementById('cSecret').value = '';
            document.getElementById('cSecretField').hidden = false;
            document.getElementById('cEditSecretHint').hidden = true;
            document.getElementById('credModal').hidden = false;
            document.getElementById('cName').focus();
        }

        function openEdit(id, name, type) {
            editId = id;
            document.getElementById('credTitle').textContent = 'Edit Credential';
            document.getElementById('cName').value = name;
            document.getElementById('cType').value = type;
            // No secret field when editing metadata — the hint below explains why and
            // points at the actual way to change it, so this isn't mistaken for a no-op save.
            document.getElementById('cSecretField').hidden = true;
            document.getElementById('cEditSecretHint').hidden = false;
            document.getElementById('credModal').hidden = false;
            document.getElementById('cName').focus();
        }

        function closeCred() {
            document.getElementById('credModal').hidden = true;
        }

        async function saveCred() {
            const name = document.getElementById('cName').value.trim();
            const type = document.getElementById('cType').value;
            if (!name) {
                toast('Name is required.');
                return;
            }

            let url, method, body;
            if (editId === null) {
                const secret = document.getElementById('cSecret').value.trim();
                if (!secret) {
                    toast('Secret is required.');
                    return;
                }
                url = '/api/v1/admin/credentials';
                method = 'POST';
                body = JSON.stringify({name, type, secret});
            } else {
                url = '/api/v1/admin/credentials/' + editId;
                method = 'PUT';
                body = JSON.stringify({name, type});
            }

            const resp = await fetch(url, {
                method,
                headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': CSRF},
                body,
            });
            if (!resp.ok) {
                toast('Save failed (' + resp.status + ').');
                return;
            }
            closeCred();
            toast('Credential saved.');
            location.reload();
        }

        function openRotate(id, name) {
            if (!id) {
                toast('No credential selected to rotate.');
                return;
            }
            rotateId = id;
            document.getElementById('rotateTitle').textContent = 'Rotate Secret — ' + name;
            document.getElementById('rSecret').value = '';
            document.getElementById('rotateModal').hidden = false;
            document.getElementById('rSecret').focus();
        }

        function closeRotate() {
            rotateId = null;
            document.getElementById('rotateModal').hidden = true;
        }

        function resetDialogs() {
            editId = null;
            rotateId = null;
            document.getElementById('credModal').hidden = true;
            document.getElementById('rotateModal').hidden = true;
        }

        async function saveRotate() {
            if (!rotateId) {
                toast('No credential selected. Click Rotate on a credential row first.');
                return;
            }
            const secret = document.getElementById('rSecret').value.trim();
            if (!secret) {
                toast('Secret is required.');
                return;
            }
            const resp = await fetch('/api/v1/admin/credentials/' + rotateId + '/secret', {
                method: 'PUT',
                headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': CSRF},
                body: JSON.stringify({secret}),
            });
            if (!resp.ok) {
                let msg = 'Rotate failed (' + resp.status + ').';
                try {
                    const payload = await resp.json();
                    const apiMessage = payload?.detail;
                    if (apiMessage) {
                        msg = 'Rotate failed: ' + apiMessage;
                    }
                } catch {
                    // Keep generic status-based message when no JSON error payload is present.
                }
                toast(msg);
                return;
            }
            closeRotate();
            toast('Secret rotated.');
        }

        async function deleteCredential(id, name) {
            if (!confirm('Delete credential "' + name + '"?')) return;
            const resp = await fetch('/api/v1/admin/credentials/' + id, {
                method: 'DELETE',
                headers: {'X-CSRF-TOKEN': CSRF},
            });
            if (resp.status === 409) {
                toast('Cannot delete: credential is in use by a target.');
                return;
            }
            if (!resp.ok && resp.status !== 204) {
                toast('Delete failed (' + resp.status + ').');
                return;
            }
            const row = document.getElementById('cred-row-' + id);
            if (row) row.remove();
            toast('Credential deleted.');
        }

        document.addEventListener('keydown', e => {
            if (e.key === 'Escape') {
                closeCred();
                closeRotate();
            }
        });

        // Browser back/forward cache can restore an open dialog while script state is fresh.
        // Force a clean modal state so actions always start from a selected row.
        document.addEventListener('DOMContentLoaded', resetDialogs);
        window.addEventListener('pageshow', resetDialogs);
    </script>
}
