@page "/admin/users"
@using JMW.Discovery.Server.Pages.Admin
@model JMW.Discovery.Server.Pages.Admin.UsersModel
@{
    ViewData["Title"] = "Users — JMW Discovery";
    ViewData["ActiveNav"] = "system";
    int adminCount = Model.Users.Count(u => u.Role == "admin");
}

<main class="main">
    <div class="page-head">
        <h1>Users</h1>
    </div>

    <partial name="_HubTabs" model="@(new HubTabsModel(HubTabSets.System, "/admin/users", "System views"))"/>

    <div class="section">
        <p class="prose text-dim" style="margin-bottom:var(--space-3)">
            SSO logins auto-provision as <code>viewer</code> on first sign-in — promote them to
            <code>admin</code> here. At least one admin must always remain.
        </p>
        <table class="data" data-client-grid aria-label="Users">
            <thead>
            <tr>
                <th data-col-key="username">Username</th>
                <th data-col-key="role">Role</th>
                <th data-col-key="created">Created</th>
                <th data-col-key="last-active">Last Active</th>
                <th data-no-sort></th>
            </tr>
            </thead>
            <tbody>
            @foreach (UsersModel.UserRow u in Model.Users)
            {
                bool isLastAdmin = u.Role == "admin" && adminCount <= 1;
                bool isSelf = u.UserId == Model.CurrentUserId;
                <tr id="row-@u.UserId">
                    <td>@u.Username @if (isSelf)
                        {
                            <span class="text-dim" style="font-size:var(--fs-sm)">(you)</span>
                        }
                    </td>
                    <td>
                        <span class="role-badge @(u.Role == "admin" ? "" : "readonly")">@u.Role</span>
                    </td>
                    <td class="text-dim" style="font-size:var(--fs-sm)" title="@u.CreatedAt.ToString("O")">
                        @ViewFormat.RelativeTime(u.CreatedAt)
                    </td>
                    <td class="text-dim" style="font-size:var(--fs-sm)">
                        @(u.LastSeen.HasValue ? ViewFormat.RelativeTime(u.LastSeen.Value) : "never")
                    </td>
                    <td style="display:flex;gap:var(--space-2)">
                        @if (u.Role == "admin")
                        {
                            <button class="btn btn-sm" @(isLastAdmin ? "disabled" : "")
                                    title="@(isLastAdmin ? "Cannot demote the last remaining admin" : "")"
                                    onclick="setRole('@u.UserId', 'viewer')">Demote to viewer</button>
                        }
                        else
                        {
                            <button class="btn btn-sm btn-primary" onclick="setRole('@u.UserId', 'admin')">Promote to
                                admin
                            </button>
                        }
                        <button class="btn btn-sm btn-danger" @(isLastAdmin ? "disabled" : "")
                                title="@(isLastAdmin ? "Cannot delete the last remaining admin" : "")"
                                onclick="deleteUser('@u.UserId', '@u.Username')">Delete</button>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    </div>
</main>

<div class="toast" id="toast" hidden></div>

@section Scripts {
    <script>
        const CSRF = '@Model.AntiforgeryToken';

        function toast(msg) {
            const t = document.getElementById('toast');
            t.textContent = msg;
            t.hidden = false;
            setTimeout(() => t.hidden = true, 3000);
        }

        async function setRole(userId, role) {
            const resp = await fetch('/api/v1/admin/users/' + userId + '/role', {
                method: 'PATCH',
                headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': CSRF},
                body: JSON.stringify({role: role}),
            });

            if (resp.ok) {
                location.reload();
            } else {
                const j = await resp.json().catch(() => null);
                toast('Error: ' + (j?.detail ?? resp.status));
            }
        }

        async function deleteUser(userId, username) {
            if (!confirm('Delete user "' + username + '"? This cannot be undone.')) {
                return;
            }

            const resp = await fetch('/api/v1/admin/users/' + userId, {
                method: 'DELETE',
                headers: {'X-CSRF-TOKEN': CSRF},
            });

            if (resp.ok || resp.status === 204) {
                document.getElementById('row-' + userId)?.remove();
            } else {
                const j = await resp.json().catch(() => null);
                toast('Error: ' + (j?.detail ?? resp.status));
            }
        }
    </script>
}
