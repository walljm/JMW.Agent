@page "/admin/conflicts"
@model JMW.Discovery.Server.Pages.Admin.ConflictsModel
@{
    ViewData["Title"] = "Fingerprint Conflicts — JMW Discovery";
    ViewData["ActiveNav"] = "data";
}
<main class="main">
    <div class="page-head">
        <h1>Fingerprint Conflicts</h1>
        <span class="meta">@Model.Conflicts.Count shown</span>
    </div>

    <partial name="_HubTabs" model="@(new HubTabsModel(HubTabSets.Data, "/admin/conflicts", "Data views"))"/>

    <p class="prose text-dim">
        These fingerprints are shared by more than one device. Merge to combine them into a single record, or exclude to
        suppress future auto-merge for this fingerprint.
    </p>

    <partial name="_FilterBar" model="Model.FilterBar"/>

    <partial name="_ConflictsTable" model="Model"/>
</main>

<!-- Merge conflict drawer -->
<div class="modal-scrim" id="mergeModal" hidden role="dialog" aria-modal="true" aria-labelledby="mergeTitle">
    <div class="modal">
        <header>
            <h3 id="mergeTitle">Merge Devices</h3>
            <button class="btn btn-sm" onclick="closeMerge()" aria-label="Close">✕</button>
        </header>
        <div class="body">
            <p class="prose text-dim" id="mergeDesc"></p>
            <label>
                Survivor device (keep this one)
                <select id="mergeWinner" class="input" style="width:100%;margin-top:var(--space-2)"></select>
            </label>
        </div>
        <footer>
            <button class="btn" onclick="closeMerge()">Cancel</button>
            <button class="btn btn-primary" onclick="doMerge()">Merge</button>
        </footer>
    </div>
</div>

@section Scripts {
    <script>
        const csrfToken = '@Model.AntiforgeryToken';
        let mergeFpType = '', mergeFpValue = '';

        function openMerge(fpType, fpValue, deviceIds) {
            mergeFpType = fpType;
            mergeFpValue = fpValue;
            document.getElementById('mergeDesc').textContent =
                'Merging fingerprint ' + fpType + ':' + fpValue + '. All other devices will be aliased to the survivor.';
            const sel = document.getElementById('mergeWinner');
            sel.innerHTML = deviceIds.map(function (id) {
                const opt = document.createElement('option');
                opt.value = id;
                opt.textContent = id;
                return opt.outerHTML;
            }).join('');
            document.getElementById('mergeModal').hidden = false;
        }

        function closeMerge() {
            document.getElementById('mergeModal').hidden = true;
        }

        async function doMerge() {
            const winner = document.getElementById('mergeWinner').value;
            const resp = await fetch('/api/v1/admin/conflicts/' + encodeURIComponent(mergeFpType) + '/' + encodeURIComponent(mergeFpValue) + '/resolve', {
                method: 'POST',
                headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken},
                body: JSON.stringify({action: 'merge', winner_device_id: winner}),
            });
            if (resp.ok) {
                closeMerge();
                location.reload();
            } else {
                const body = await resp.json();
                alert('Error: ' + (body.detail ?? resp.status));
            }
        }

        // Event delegation — reads data-* attributes so no JS string injection from network data.
        document.addEventListener('click', async function (e) {
            const mergeBtn = e.target.closest('.js-merge');
            if (mergeBtn) {
                const fpType = mergeBtn.dataset.fpType;
                const fpValue = mergeBtn.dataset.fpValue;
                const deviceIds = JSON.parse(mergeBtn.dataset.deviceIds);
                openMerge(fpType, fpValue, deviceIds);
                return;
            }

            const excludeBtn = e.target.closest('.js-exclude');
            if (excludeBtn) {
                const fpType = excludeBtn.dataset.fpType;
                const fpValue = excludeBtn.dataset.fpValue;
                if (!confirm('Exclude fingerprint ' + fpType + ':' + fpValue + ' from conflict detection?')) return;
                const resp = await fetch('/api/v1/admin/conflicts/' + encodeURIComponent(fpType) + '/' + encodeURIComponent(fpValue) + '/resolve', {
                    method: 'POST',
                    headers: {'Content-Type': 'application/json', 'X-CSRF-TOKEN': csrfToken},
                    body: JSON.stringify({action: 'exclude'}),
                });
                if (resp.ok) {
                    location.reload();
                } else {
                    const body = await resp.json();
                    alert('Error: ' + (body.detail ?? resp.status));
                }
            }
        });
    </script>
}
