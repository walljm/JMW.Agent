@using JMW.Discovery.Server.Admin
@model JMW.Discovery.Server.Pages.Admin.CredentialsModel

<div id="credentials-table" class="grid-panel">
    @if (Model.Credentials.Count == 0)
    {
        <p class="prose text-dim">No credentials match the current filters.</p>
    }
    else
    {
        <table class="data">
            <thead>
            <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Created</th>
                <th>Updated</th>
                <th></th>
            </tr>
            </thead>
            <tbody id="cred-tbody">
            @foreach (CredentialListItem cred in Model.Credentials)
            {
                <tr id="cred-row-@cred.CredentialId">
                    <td>@cred.Name</td>
                    <td>@cred.Type</td>
                    <td><time data-utc="@ViewFormat.IsoUtc(cred.CreatedAt)">@cred.CreatedAt.ToString("yyyy-MM-dd HH:mm") UTC</time></td>
                    <td><time data-utc="@ViewFormat.IsoUtc(cred.UpdatedAt)">@cred.UpdatedAt.ToString("yyyy-MM-dd HH:mm") UTC</time></td>
                    <td style="display:flex;gap:var(--space-2)">
                        <button class="btn btn-sm"
                                onclick="openEdit('@cred.CredentialId', '@cred.Name', '@cred.Type')">
                            Edit
                        </button>
                        <button class="btn btn-sm"
                                onclick="openRotate('@cred.CredentialId', '@cred.Name')">
                            Rotate
                        </button>
                        <button class="btn btn-sm" style="color:var(--crit)"
                                onclick="deleteCredential('@cred.CredentialId', '@cred.Name')">
                            Delete
                        </button>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <partial name="_Pagination" model="Model.Pagination"/>
    }
</div>
