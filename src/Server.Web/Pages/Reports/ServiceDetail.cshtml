@page "/services/{id}"
@using JMW.Discovery.Server.FactViews
@using JMW.Discovery.Server.Reporting
@using JMW.Discovery.Server.Pages.Reports
@model JMW.Discovery.Server.Pages.Reports.ServiceDetailModel
@{
    ViewData["Title"] = Model.Service + " — JMW Discovery";
    ViewData["ActiveNav"] = "services";

    static string CaClass(string? status) =>
        string.IsNullOrEmpty(status) ? "status info"
        : string.Equals(status, "ok", StringComparison.OrdinalIgnoreCase)
        || string.Equals(status, "healthy", StringComparison.OrdinalIgnoreCase) ? "status ok"
        : "status warn";

    // Same 30-day threshold as _CaServicesTable/_TerrainCaTable/DashboardQueries' CA-expiry widgets.
    static bool IsExpiringSoon(DateTime? notAfter) =>
        notAfter is not null && notAfter.Value <= DateTime.UtcNow.AddDays(30);
}
<main class="main data-grid-page">
    <div class="page-head">
        <h1><a href="/services" style="color:var(--text-dim)">Services</a> / @Model.Service</h1>
    </div>

    <div class="detail-body">
        <nav class="section-nav" role="tablist" aria-label="Service sections" data-default="@Model.DefaultSection">
            @foreach (DeviceSectionGroup navGroup in Model.NavGroups)
            {
                <div class="section-nav-group">
                    @if (navGroup.Items.Count > 1)
                    {
                        <button type="button" class="group-label-btn eyebrow"
                                data-panels="@string.Join(",", navGroup.Items.Select(i => i.Id))"
                                data-group-label="@navGroup.Label"
                                title="View all @navGroup.Label sections together">
                            @navGroup.Label
                            <span class="group-label-all">View all</span>
                        </button>
                    }
                    else
                    {
                        <span class="group-label eyebrow">@navGroup.Label</span>
                    }
                    @foreach (DeviceSectionItem item in navGroup.Items)
                    {
                        <button type="button" class="section-nav-item" role="tab" aria-selected="false"
                                data-tab="@item.Id">
                            <span class="section-nav-label">@item.Label</span>
                            @if (item.Count is { } count)
                            {
                                <span class="section-nav-count">@count</span>
                            }
                        </button>
                    }
                </div>
            }
        </nav>
        <div class="section-panels">

            <div class="tabpanel" role="tabpanel" data-panel="summary" hidden>
                <div class="identity">
                    <div>
                        <div class="title">@(string.IsNullOrEmpty(Model.ServiceId) ? Model.Service : Model.ServiceId)</div>
                        <dl class="kv" style="margin-top:var(--space-3)">
                            <dt>Service ID</dt>
                            <dd class="mono">@Model.Service</dd>
                            <dt>Type</dt>
                            <dd>@(Model.Type ?? "—")</dd>
                            <dt>Device</dt>
                            <dd>
                                @if (!string.IsNullOrEmpty(Model.DeviceId))
                                {
                                    <a href="/devices/@Model.DeviceId" class="mono">@Model.DeviceId</a>
                                }
                                else
                                {
                                    <span>—</span>
                                }
                            </dd>
                        </dl>
                    </div>
                    @{
                        (string Tab, string Label, int Count)[] atGlance =
                        [
                            ("dns", "DNS Zones", Model.Zones.Count),
                            ("dns", "DNS Records", Model.Records.Count),
                            ("dhcp", "DHCP Scopes", Model.Scopes.Count),
                            ("ca", "Provisioners", Model.Provisioners.Count),
                        ];
                    }
                    @if (atGlance.Any(s => s.Count > 0))
                    {
                        <div class="identity-stats stat-row">
                            @foreach ((string tab, string label, int count) in atGlance)
                            {
                                @if (count > 0)
                                {
                                    <div class="stat">
                                        <a class="stat-head" href="#" onclick="switchTab('@tab'); return false;">
                                            <div class="label">@label</div>
                                            <div class="value">@count</div>
                                        </a>
                                    </div>
                                }
                            }
                        </div>
                    }
                </div>

                @if (Model.CaStatus is not null || Model.RootSubjectDn is not null)
                {
                    <div style="margin-top:var(--space-5)">
                        <div class="tabpanel-heading">
                            Certificate Authority
                            <a href="#" onclick="switchTab('ca'); return false;"
                               style="float:right;font-size:var(--fs-sm);font-weight:var(--fw-normal)">View all →</a>
                        </div>
                        <dl class="kv">
                            <dt>Status</dt>
                            <dd>
                                @if (!string.IsNullOrEmpty(Model.CaStatus))
                                {
                                    <span class="@CaClass(Model.CaStatus)">@Model.CaStatus</span>
                                }
                                else
                                {
                                    @:—
                                }
                            </dd>
                            <dt>Root Expires</dt>
                            <dd>
                                @if (Model.RootNotAfter.HasValue)
                                {
                                    <time data-utc="@ViewFormat.IsoUtc(Model.RootNotAfter.Value)">@Model.RootNotAfter.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                                    @if (IsExpiringSoon(Model.RootNotAfter))
                                    {
                                        <span class="status warn" style="margin-left:var(--space-2)">expiring soon</span>
                                    }
                                }
                                else
                                {
                                    @:—
                                }
                            </dd>
                        </dl>
                    </div>
                }

                @if (Model.TotalQueries.HasValue || Model.BlockedPct.HasValue)
                {
                    <div style="margin-top:var(--space-5)">
                        <div class="tabpanel-heading">
                            DNS Activity
                            <a href="#" onclick="switchTab('dns'); return false;"
                               style="float:right;font-size:var(--fs-sm);font-weight:var(--fw-normal)">View all →</a>
                        </div>
                        <dl class="kv">
                            <dt>Total Queries</dt>
                            <dd>@(Model.TotalQueries?.ToString() ?? "—")</dd>
                            <dt>Blocked %</dt>
                            <dd>@(Model.BlockedPct.HasValue ? Model.BlockedPct.Value.ToString("0.#") + "%" : "—")</dd>
                        </dl>
                        @{
                            const double sparkW = 280;
                            const double sparkH = 48;
                            string? sparkPath = ServiceDetailModel.BuildSparklinePath(Model.BlockedPctTrend, sparkW, sparkH);
                        }
                        @if (sparkPath is not null)
                        {
                            <div style="margin-top:var(--space-3)">
                                <div class="fs-xs text-dim" style="margin-bottom:var(--space-1)">Blocked % · last 30 days</div>
                                <svg width="@sparkW" height="@sparkH" viewBox="0 0 @sparkW @sparkH" role="img"
                                     aria-label="Blocked query percentage over the last 30 days, ending at @(Model.BlockedPct?.ToString("0.#") ?? "—")%">
                                    <title>Blocked % over the last 30 days (currently @(Model.BlockedPct?.ToString("0.#") ?? "—")%)</title>
                                    <path d="@sparkPath" fill="none" stroke="var(--accent)" stroke-width="2"
                                          stroke-linecap="round" stroke-linejoin="round"/>
                                </svg>
                            </div>
                        }
                    </div>
                }
            </div>

            <div class="tabpanel" role="tabpanel" data-panel="ca" hidden>
                <dl class="kv">
                    <dt>Status</dt>
                    <dd>
                        @if (!string.IsNullOrEmpty(Model.CaStatus))
                        {
                            <span class="@CaClass(Model.CaStatus)">@Model.CaStatus</span>
                        }
                        else
                        {
                            @:—
                        }
                    </dd>
                    <dt>Address</dt>
                    <dd class="mono">@(Model.CaAddress ?? "—")</dd>
                    <dt>Root Subject</dt>
                    <dd>@(Model.RootSubjectDn ?? "—")</dd>
                    <dt>Root Valid From</dt>
                    <dd>
                        @if (Model.RootNotBefore.HasValue)
                        {
                            <time data-utc="@ViewFormat.IsoUtc(Model.RootNotBefore.Value)">@Model.RootNotBefore.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                        }
                        else
                        {
                            @:—
                        }
                    </dd>
                    <dt>Root Expires</dt>
                    <dd>
                        @if (Model.RootNotAfter.HasValue)
                        {
                            <time data-utc="@ViewFormat.IsoUtc(Model.RootNotAfter.Value)">@Model.RootNotAfter.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                            @if (IsExpiringSoon(Model.RootNotAfter))
                            {
                                <span class="status warn" style="margin-left:var(--space-2)">expiring soon</span>
                            }
                        }
                        else
                        {
                            @:—
                        }
                    </dd>
                    <dt>Root Fingerprint</dt>
                    <dd class="mono">@(Model.RootFingerprint ?? "—")</dd>
                    <dt>Intermediate Subject</dt>
                    <dd>@(Model.IntSubjectDn ?? "—")</dd>
                    <dt>Intermediate Valid From</dt>
                    <dd>
                        @if (Model.IntNotBefore.HasValue)
                        {
                            <time data-utc="@ViewFormat.IsoUtc(Model.IntNotBefore.Value)">@Model.IntNotBefore.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                        }
                        else
                        {
                            @:—
                        }
                    </dd>
                    <dt>Intermediate Expires</dt>
                    <dd>
                        @if (Model.IntNotAfter.HasValue)
                        {
                            <time data-utc="@ViewFormat.IsoUtc(Model.IntNotAfter.Value)">@Model.IntNotAfter.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                            @if (IsExpiringSoon(Model.IntNotAfter))
                            {
                                <span class="status warn" style="margin-left:var(--space-2)">expiring soon</span>
                            }
                        }
                        else
                        {
                            @:—
                        }
                    </dd>
                </dl>

                @if (Model.Provisioners.Count > 0)
                {
                    <h3 class="section-title" style="margin-top:var(--space-5)">Provisioners</h3>
                    <div class="detail-table-scroll">
                        <table class="data" aria-label="Provisioners" data-client-grid>
                            <thead>
                            <tr>
                                <th data-col-key="name">Name</th>
                                <th data-col-key="type">Type</th>
                                <th data-col-key="default-duration">Default Duration</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (ServiceProvisioner p in Model.Provisioners)
                            {
                                <tr>
                                    <td>@p.Provisioner</td>
                                    <td>@(p.Type ?? "—")</td>
                                    <td>@(p.DefaultDuration ?? "—")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="tabpanel" role="tabpanel" data-panel="dns" hidden>
                @if (Model.TotalQueries.HasValue || Model.BlockedPct.HasValue)
                {
                    <dl class="kv">
                        <dt>Total Queries</dt>
                        <dd>@(Model.TotalQueries?.ToString() ?? "—")</dd>
                        <dt>Total Blocked</dt>
                        <dd>@(Model.TotalBlocked?.ToString() ?? "—")</dd>
                        <dt>Blocked %</dt>
                        <dd>@(Model.BlockedPct.HasValue ? Model.BlockedPct.Value.ToString("0.#") + "%" : "—")</dd>
                    </dl>
                }
                @if (Model.Zones.Count == 0)
                {
                    <div class="empty">No DNS zones for this service.</div>
                }
                else
                {
                    <div class="detail-table-scroll">
                        <table class="data" aria-label="DNS zones" data-client-grid>
                            <thead>
                            <tr>
                                <th data-col-key="zone">Zone</th>
                                <th data-col-key="type">Type</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (ServiceZone z in Model.Zones)
                            {
                                <tr>
                                    <td class="mono">@z.Zone</td>
                                    <td>@(z.Type ?? "—")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }

                @if (Model.Records.Count > 0)
                {
                    <h3 class="section-title" style="margin-top:var(--space-5)">Records (@Model.Records.Count)</h3>
                    <div class="detail-table-scroll">
                        <table class="data" aria-label="DNS records" data-client-grid>
                            <thead>
                            <tr>
                                <th data-col-key="zone">Zone</th>
                                <th data-col-key="record">Record</th>
                                <th data-col-key="type">Type</th>
                                <th data-col-key="value">Value</th>
                                <th data-col-key="ttl">TTL</th>
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (ServiceDnsRecord r in Model.Records)
                            {
                                <tr>
                                    <td class="mono">@r.Zone</td>
                                    <td class="mono">@r.Record</td>
                                    <td>@r.Type</td>
                                    <td class="mono">@(r.Value ?? "—")</td>
                                    <td>@(r.Ttl?.ToString() ?? "—")</td>
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                }
            </div>

            <div class="tabpanel" role="tabpanel" data-panel="dhcp" hidden>
                <div class="detail-table-scroll">
                    <table class="data" aria-label="DHCP scopes" data-client-grid>
                        <thead>
                        <tr>
                            <th data-col-key="scope">Scope</th>
                            <th data-col-key="enabled">Enabled</th>
                            <th data-col-key="range">Range</th>
                            <th data-col-key="subnet-mask">Subnet Mask</th>
                            <th data-col-key="gateway">Gateway</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (ServiceScope s in Model.Scopes)
                        {
                            <tr>
                                <td class="mono">@s.Scope</td>
                                <td>@(s.Enabled.HasValue ? s.Enabled.Value ? "yes" : "no" : "—")</td>
                                <td class="mono">@(string.IsNullOrEmpty(s.StartAddress) ? "—" : s.StartAddress + " – " + (s.EndAddress ?? "?"))</td>
                                <td class="mono">@(s.SubnetMask ?? "—")</td>
                                <td class="mono">@(s.Gateway ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>

            @foreach (RenderedFactView view in Model.FactViews)
            {
                <div class="tabpanel" role="tabpanel" data-panel="@ServiceDetailModel.FactViewSectionId(view.Title)" hidden>
                    <div class="detail-table-scroll">
                        <table class="data" aria-label="@view.Title" data-client-grid>
                            <thead>
                            <tr>
                                @foreach (string header in view.Headers)
                                {
                                    <th data-col-key="@header">@header</th>
                                }
                            </tr>
                            </thead>
                            <tbody>
                            @foreach (IReadOnlyList<FactCell> row in view.Rows)
                            {
                                <tr>
                                    @foreach (FactCell cell in row)
                                    {
                                        @if (cell.SortValue is not null)
                                        {
                                            <td data-sort="@cell.SortValue">@(cell.Display ?? "—")</td>
                                        }
                                        else
                                        {
                                            <td>@(cell.Display ?? "—")</td>
                                        }
                                    }
                                </tr>
                            }
                            </tbody>
                        </table>
                    </div>
                </div>
            }

            <div class="tabpanel" role="tabpanel" data-panel="allfacts" hidden>
                <div class="detail-table-scroll">
                    <table class="data" aria-label="Service facts" data-client-grid>
                        <thead>
                        <tr>
                            <th data-col-key="attribute">Attribute</th>
                            <th data-col-key="key">Key</th>
                            <th data-col-key="value">Value</th>
                        </tr>
                        </thead>
                        <tbody>
                        @foreach (FactViewFact fact in Model.AllFacts)
                        {
                            <tr>
                                <td class="mono">@fact.AttributePath</td>
                                <td class="mono">@(string.IsNullOrEmpty(fact.Key) ? "—" : fact.Key)</td>
                                <td>@(fact.Value ?? "—")</td>
                            </tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</main>

@* Section-nav behavior (tab switching, "view all" grouping, ARIA linking, keyboard nav) is
   handled by the shared /js/section-nav.js, loaded globally in _Layout.cshtml. Client-side
   column sorting + search for these tables comes from client-grid.js (data-client-grid). *@
