@using JMW.Discovery.Server.Pages.Reports
@model JMW.Discovery.Server.Pages.Reports.DashboardModel
@{
    string? err = Model.PanelError("new-devices");
    ActivityCountsVm? counts = Model.ActivityCounts;
}
<dash-panel panel-name="new-devices" title="New devices" refresh-seconds="30"
            action-href="/all-hosts?added=recent" action-text="View →">
    @if (err is not null)
    {
        <partial name="_SectionError" model="err"/>
    }
    else
    {
        @if (counts is not null)
        {
            <p class="meta" style="margin-top:calc(-1 * var(--space-2));margin-bottom:var(--space-3)">
                @counts.NewDevices7d first seen in the
                last @DashboardModel.NewDeviceDays days
            </p>
        }

        @if (Model.NewDevices.Count == 0)
        {
            <div class="empty">No new devices in the
                last @DashboardModel.NewDeviceDays days.
            </div>
        }
        else
        {
            <div class="act-list">
                @foreach (NewDeviceRow d in Model.NewDevices)
                {
                    string? badgeCls = d.ManagementStatus switch
                    {
                        "discovered" => "badge-discovered",
                        "managed" => "badge-managed",
                        _ => null,
                    };
                    <a class="act-item" href="/devices/@d.DeviceId?from=dashboard">
                        <span class="act-main">
                            @d.Display
                            @if (badgeCls is not null)
                            {
                                <span class="@badgeCls">@d.ManagementStatus</span>
                            }
                        </span>
                        <span class="act-when">@ViewFormat.RelativeTime(d.CreatedAt.UtcDateTime)</span>
                    </a>
                }
            </div>
        }
    }
</dash-panel>
