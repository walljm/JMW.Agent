@using JMW.Discovery.Server.Reporting
@model JMW.Discovery.Server.Pages.Reports.AllHostsModel

<div id="hosts-table" class="grid-panel">
    <partial name="_SectionError" model="Model.LoadError"/>

    @if (Model.LoadError is null && Model.Hosts.Count == 0)
    {
        <div class="empty">No hosts match the current filters.</div>
    }
    else if (Model.LoadError is null)
    {
        <div class="grid-scroll">
            <table class="data" aria-label="All hosts">
                <thead>
                <tr>
                    <th sort-key="hostname" sort-grid="Model.Grid" sort-target="#hosts-table">Hostname</th>
                    <th sort-key="ip" sort-grid="Model.Grid" sort-target="#hosts-table">IP Address</th>
                    <th sort-key="mac" sort-grid="Model.Grid" sort-target="#hosts-table">MAC</th>
                    <th style="cursor:default">OUI</th>
                    <th sort-key="vendor" sort-grid="Model.Grid" sort-target="#hosts-table">Vendor</th>
                    <th sort-key="os" sort-grid="Model.Grid" sort-target="#hosts-table">OS</th>
                    <th sort-key="status" sort-grid="Model.Grid" sort-target="#hosts-table">Status</th>
                    <th style="cursor:default">Discovery Sources</th>
                    <th sort-key="last_seen" sort-grid="Model.Grid" sort-target="#hosts-table">Last Seen</th>
                </tr>
                </thead>
                <tbody>
                @foreach (HostListItem host in Model.Hosts)
                {
                    <tr data-href="/devices/@host.DeviceId?from=all-hosts" style="cursor:pointer">
                        <td>@(string.IsNullOrEmpty(host.Hostname) ? "—" : host.Hostname)</td>
                        <td class="mono">@(string.IsNullOrEmpty(host.Ip) ? "—" : host.Ip)</td>
                        <td class="mono">
                            @if (!string.IsNullOrEmpty(host.Mac))
                            {
                                @ViewFormat.FormatMac(host.Mac)
                            }
                            else if (!string.IsNullOrEmpty(host.ObscuredMac))
                            {
                                <span class="text-dim" title="Obscured MAC (Google Wifi/OnHub) — firmware masks the device bytes; no unique ARP/DHCP match was found to reconstruct the full address, but the OUI prefix is still reliable">@host.ObscuredMac</span>
                            }
                            else
                            {
                                @:—
                            }
                        </td>
                        <td class="text-dim" title="NIC manufacturer from MAC OUI">@ViewFormat.FormatOui(host.Oui, host.OuiCountry)</td>
                        <td>@(host.Vendor ?? "—")</td>
                        <td>@(ViewFormat.FormatOs(host.OsFamily, host.OsDistro))</td>
                        <td>
                            @if (host.ManagementStatus == "managed")
                            {
                                <span class="badge-managed">Managed</span>
                            }
                            else
                            {
                                <span class="badge-discovered">Discovered</span>
                            }
                        </td>
                        <td style="white-space:nowrap">
              <span class="tags">
                @foreach (string src in host.Sources)
                  {
                      <span class="tag">@src</span>
                  }
              </span>
                        </td>
                        <td>
                            @if (host.LastSeen.HasValue)
                            {
                                <time data-utc="@ViewFormat.IsoUtc(host.LastSeen.Value)">@host.LastSeen.Value.ToString("yyyy-MM-dd HH:mm") UTC</time>
                            }
                            else
                            {
                                @:—
                            }
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Pagination"/>
    }
</div>
