@page "/all-hosts"
@model JMW.Discovery.Server.Pages.Reports.AllHostsModel
@{
    ViewData["Title"] = "All Hosts — JMW Discovery";
    ViewData["ActiveNav"] = "all-hosts";
}
<main class="main data-grid-page">
    <div class="page-head">
        <h1>All Hosts</h1>
        <span class="meta">@Model.Hosts.Count hosts shown</span>
    </div>

    <partial name="_FilterBar" model="Model.FilterBar"/>

    <partial name="_HostsTable" model="Model"/>
</main>
