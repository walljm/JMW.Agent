@using JMW.Discovery.Server.Reporting
@model JMW.Discovery.Server.Pages.Reports.ServicesModel
@{
    // Every service type gets its own one-line glance value here instead of forcing every
    // row through the same fixed DNS-shaped columns (CA status/expiry/query count), which
    // left non-DNS services (e.g. Home Assistant) with dashes in most columns.
    static string Highlights(ServiceListItem s)
    {
        List<string> parts = [];
        if (s.TotalQueries.HasValue)
        {
            string blocked = s.BlockedPct.HasValue ? $" ({s.BlockedPct.Value:0.#}% blocked)" : "";
            parts.Add($"{s.TotalQueries.Value:N0} queries{blocked}");
        }

        if (!string.IsNullOrEmpty(s.CaStatus))
        {
            parts.Add($"CA {s.CaStatus}");
        }

        return parts.Count > 0 ? string.Join(" · ", parts) : "—";
    }
}

<div id="services-table" class="grid-panel">
    <partial name="_SectionError" model="Model.LoadError"/>

    @if (Model.LoadError is null && Model.Services.Count == 0)
    {
        <div class="empty">No services match the current filters.</div>
    }
    else if (Model.LoadError is null)
    {
        <div class="grid-scroll">
            <table class="data" aria-label="Services">
                <thead>
                <tr>
                    <th style="cursor:default" data-col-key="host">Host</th>
                    <th style="cursor:default" data-col-key="ip">IP</th>
                    <th style="cursor:default" data-col-key="type">Type</th>
                    <th style="cursor:default" data-col-key="highlights">Highlights</th>
                </tr>
                </thead>
                <tbody>
                @foreach (ServiceListItem s in Model.Services)
                {
                    string? hostName = !string.IsNullOrEmpty(s.HostFriendlyName) ? s.HostFriendlyName : s.HostHostname;
                    <tr data-href="/services/@Uri.EscapeDataString(s.Service)" style="cursor:pointer">
                        <td>
                            @if (!string.IsNullOrEmpty(s.DeviceId))
                            {
                                <a href="/devices/@s.DeviceId?from=services" onclick="event.stopPropagation()">@(string.IsNullOrEmpty(hostName) ? "unnamed host" : hostName)</a>
                            }
                            else
                            {
                                <span title="No host device is linked to this service — see below">—</span>
                            }
                        </td>
                        <td class="mono">@(string.IsNullOrEmpty(s.HostIp) ? "—" : s.HostIp)</td>
                        <td>@(s.Type ?? "—")</td>
                        <td>@Highlights(s)</td>
                    </tr>
                }
                </tbody>
            </table>
        </div>

        <partial name="_Pagination" model="Model.Pagination"/>
    }
</div>
